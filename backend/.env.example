# Copia este archivo a .env y completa los valores. NUNCA subas .env al repo.
DJANGO_SECRET_KEY=genera-una-clave-larga-y-aleatoria
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (si se omiten, usa SQLite local)
POSTGRES_DB=grc
POSTGRES_USER=grc_user
POSTGRES_PASSWORD=cambia-esta-clave
POSTGRES_HOST=db
POSTGRES_PORT=5432
